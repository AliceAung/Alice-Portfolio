---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import aliceProfile from '../assets/alice-profile.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead 
			title={`About — ${SITE_TITLE}`} 
			description="Learn about Alice Aung — a passionate Marketing & Business Development professional with expertise in brand strategy, market research, and building strategic partnerships." 
		/>
	</head>
	<body>
		<Header />
		<main class="about-page">
			<!-- Page Hero -->
			<section class="about-hero">
				<div class="container">
					<div class="about-hero-content">
						<div class="about-hero-text">
							<p class="section-label">About Me</p>
							<h1>Crafting Growth Through <span class="gradient-text">Strategy & Story</span></h1>
							<p class="about-intro">
								I'm Alice Aung — a Marketing & Business Development professional passionate about 
								helping brands connect authentically with their audiences and achieve sustainable growth.
							</p>
						</div>
						<div class="about-hero-image">
							<div class="about-img-container">
								<Image 
									src={aliceProfile} 
									alt="Alice Aung" 
									width={400} 
									height={500}
									class="about-photo"
								/>
								<div class="about-img-accent"></div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Bio Section -->
			<section class="about-bio section-sm">
				<div class="container">
					<div class="bio-content">
						<div class="bio-text">
							<h2>My <span class="gradient-text">Story</span></h2>
							<p>
								With a deep passion for understanding what makes brands resonate, I've dedicated my career to 
								bridging the gap between business strategy and creative marketing. My journey has taken me 
								across diverse industries — from technology startups to established enterprises — each 
								experience sharpening my ability to see opportunities where others see challenges.
							</p>
							<p>
								I believe that great marketing isn't about shouting the loudest — it's about telling 
								the right story to the right people at the right time. This philosophy drives every 
								project I take on, whether it's launching a new brand, entering a new market, or 
								building partnerships that create lasting value.
							</p>
							<p>
								When I'm not crafting strategies and analyzing market data, you'll find me exploring 
								the intersection of culture and commerce, seeking inspiration from the world around me 
								to bring fresh perspectives to every challenge.
							</p>
						</div>
						<div class="bio-highlights">
							<div class="highlight-card">
								<span class="highlight-num">5+</span>
								<span class="highlight-label">Years of Experience</span>
							</div>
							<div class="highlight-card">
								<span class="highlight-num">30+</span>
								<span class="highlight-label">Projects Completed</span>
							</div>
							<div class="highlight-card">
								<span class="highlight-num">15+</span>
								<span class="highlight-label">Brands Launched</span>
							</div>
							<div class="highlight-card">
								<span class="highlight-num">3</span>
								<span class="highlight-label">Industries Served</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Career Timeline -->
			<section class="timeline-section section" id="journey">
				<div class="container">
					<p class="section-label">Career Journey</p>
					<h2 class="section-title">Professional <span class="gradient-text">Timeline</span></h2>
					<p class="section-subtitle">Key milestones that shaped my path in marketing and business development.</p>
					
					<div class="timeline">
						<div class="timeline-item">
							<div class="timeline-marker"></div>
							<div class="timeline-content card">
								<span class="timeline-date">2024 — Present</span>
								<h3>Senior Marketing & BD Strategist</h3>
								<p>Leading cross-functional teams to develop integrated marketing strategies and forge strategic partnerships across Southeast Asian markets.</p>
							</div>
						</div>
						<div class="timeline-item">
							<div class="timeline-marker"></div>
							<div class="timeline-content card">
								<span class="timeline-date">2022 — 2024</span>
								<h3>Marketing & Business Development Lead</h3>
								<p>Spearheaded brand development initiatives, managed multi-channel campaigns, and built a network of strategic partners driving 35% revenue growth.</p>
							</div>
						</div>
						<div class="timeline-item">
							<div class="timeline-marker"></div>
							<div class="timeline-content card">
								<span class="timeline-date">2020 — 2022</span>
								<h3>Marketing Coordinator</h3>
								<p>Coordinated market research projects, assisted in campaign planning, and developed data-driven insights that shaped product positioning strategies.</p>
							</div>
						</div>
						<div class="timeline-item">
							<div class="timeline-marker"></div>
							<div class="timeline-content card">
								<span class="timeline-date">2019 — 2020</span>
								<h3>Marketing Intern</h3>
								<p>Started my journey in marketing, gaining hands-on experience in social media management, content creation, and market analysis.</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Skills & Expertise -->
			<section class="expertise-section section-sm" id="expertise">
				<div class="container">
					<p class="section-label">Expertise</p>
					<h2 class="section-title">Skills & <span class="gradient-text">Tools</span></h2>
					<div class="expertise-grid">
						<div class="expertise-category">
							<h3>Strategy & Planning</h3>
							<div class="skill-tags">
								<span class="skill-tag">Marketing Strategy</span>
								<span class="skill-tag">Brand Positioning</span>
								<span class="skill-tag">Go-to-Market Planning</span>
								<span class="skill-tag">Competitive Analysis</span>
								<span class="skill-tag">Business Development</span>
							</div>
						</div>
						<div class="expertise-category">
							<h3>Digital & Content</h3>
							<div class="skill-tags">
								<span class="skill-tag">Social Media Marketing</span>
								<span class="skill-tag">Content Strategy</span>
								<span class="skill-tag">SEO & SEM</span>
								<span class="skill-tag">Email Marketing</span>
								<span class="skill-tag">Analytics & Reporting</span>
							</div>
						</div>
						<div class="expertise-category">
							<h3>Research & Insights</h3>
							<div class="skill-tags">
								<span class="skill-tag">Market Research</span>
								<span class="skill-tag">Consumer Insights</span>
								<span class="skill-tag">Data Analysis</span>
								<span class="skill-tag">Trend Forecasting</span>
								<span class="skill-tag">Survey Design</span>
							</div>
						</div>
						<div class="expertise-category">
							<h3>Tools & Platforms</h3>
							<div class="skill-tags">
								<span class="skill-tag">Google Analytics</span>
								<span class="skill-tag">HubSpot</span>
								<span class="skill-tag">Figma</span>
								<span class="skill-tag">Canva</span>
								<span class="skill-tag">Salesforce</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Education -->
			<section class="education-section section-sm">
				<div class="container">
					<p class="section-label">Education</p>
					<h2 class="section-title">Academic <span class="gradient-text">Background</span></h2>
					<div class="education-grid">
						<div class="edu-card card">
							<div class="edu-icon">
								<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--rose-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
							</div>
							<h3>Bachelor's in Business Administration</h3>
							<p class="edu-school">Marketing & Management Concentration</p>
							<p class="edu-detail">Developed a strong foundation in strategic marketing, consumer behavior, and business management principles.</p>
						</div>
						<div class="edu-card card">
							<div class="edu-icon">
								<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--rose-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>
							</div>
							<h3>Digital Marketing Certification</h3>
							<p class="edu-school">Professional Development</p>
							<p class="edu-detail">Comprehensive certification covering SEO, social media marketing, content strategy, and analytics.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA -->
			<section class="about-cta section-sm">
				<div class="container">
					<div class="cta-card glass-card">
						<h2>Want to Work Together?</h2>
						<p>I'm always open to discussing new projects, creative ideas, or opportunities to be part of something amazing.</p>
						<a href="/contact" class="btn btn-primary">
							Get in Touch
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
						</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 100%;
		padding: 0;
	}
	.section-label {
		text-align: center;
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--rose-400);
		margin-bottom: 0.75rem;
	}

	/* ── Hero ── */
	.about-hero {
		padding: calc(var(--nav-height) + 4rem) 0 4rem;
		background: linear-gradient(180deg, var(--tan-50), var(--rose-50), var(--tan-50));
	}
	.about-hero-content {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 4rem;
		align-items: center;
	}
	.about-hero-text .section-label {
		text-align: left;
	}
	.about-hero-text h1 {
		font-size: 3rem;
		margin-bottom: 1.5rem;
	}
	.about-intro {
		font-size: 1.1rem;
		color: var(--text-secondary);
		line-height: 1.8;
	}
	.about-img-container {
		position: relative;
		max-width: 360px;
		margin: 0 auto;
	}
	.about-photo {
		width: 100%;
		height: auto;
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-xl);
		position: relative;
		z-index: 2;
	}
	.about-img-accent {
		position: absolute;
		top: 20px;
		right: -20px;
		bottom: -20px;
		left: 20px;
		border: 2px solid var(--rose-200);
		border-radius: var(--radius-xl);
		z-index: 1;
	}

	/* ── Bio ── */
	.bio-content {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 4rem;
		align-items: start;
		max-width: var(--max-width);
		margin: 0 auto;
	}
	.bio-text h2 {
		margin-bottom: 1.5rem;
	}
	.bio-text p {
		color: var(--text-secondary);
		line-height: 1.8;
	}
	.bio-highlights {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}
	.highlight-card {
		background: var(--bg-card);
		border: 1px solid var(--border-light);
		border-radius: var(--radius-lg);
		padding: 1.5rem;
		text-align: center;
		transition: all var(--transition-base);
	}
	.highlight-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
		border-color: var(--rose-200);
	}
	.highlight-num {
		display: block;
		font-family: var(--font-playfair), Georgia, serif;
		font-size: 2rem;
		font-weight: 700;
		color: var(--rose-500);
		line-height: 1.2;
		margin-bottom: 0.25rem;
	}
	.highlight-label {
		font-size: 0.8rem;
		color: var(--text-muted);
		font-weight: 500;
	}

	/* ── Timeline ── */
	.timeline-section {
		background: var(--rose-50);
	}
	.timeline {
		max-width: 700px;
		margin: 0 auto;
		position: relative;
		padding-left: 2rem;
	}
	.timeline::before {
		content: '';
		position: absolute;
		left: 7px;
		top: 0;
		bottom: 0;
		width: 2px;
		background: linear-gradient(to bottom, var(--rose-300), var(--rose-100));
	}
	.timeline-item {
		position: relative;
		margin-bottom: 2rem;
	}
	.timeline-marker {
		position: absolute;
		left: -2rem;
		top: 1.5rem;
		width: 16px;
		height: 16px;
		border-radius: 50%;
		background: var(--rose-400);
		border: 3px solid var(--bg-card);
		box-shadow: 0 0 0 3px var(--rose-200);
		z-index: 1;
	}
	.timeline-content {
		padding: 1.5rem 2rem;
	}
	.timeline-content:hover {
		transform: translateX(4px);
	}
	.timeline-date {
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--rose-400);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.timeline-content h3 {
		font-family: var(--font-inter), system-ui, sans-serif;
		font-size: 1.1rem;
		margin: 0.5rem 0;
		color: var(--text-primary);
	}
	.timeline-content p {
		font-size: 0.9rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.65;
	}

	/* ── Expertise ── */
	.expertise-section {
		background: var(--bg-primary);
	}
	.expertise-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
		max-width: 900px;
		margin: 0 auto;
	}
	.expertise-category {
		background: var(--bg-card);
		border: 1px solid var(--border-light);
		border-radius: var(--radius-lg);
		padding: 2rem;
	}
	.expertise-category h3 {
		font-family: var(--font-inter), system-ui, sans-serif;
		font-size: 1rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: var(--text-primary);
	}
	.skill-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.skill-tag {
		display: inline-block;
		padding: 0.35rem 0.85rem;
		background: var(--rose-50);
		color: var(--rose-600);
		border-radius: var(--radius-full);
		font-size: 0.8rem;
		font-weight: 500;
		border: 1px solid var(--rose-100);
		transition: all var(--transition-fast);
	}
	.skill-tag:hover {
		background: var(--rose-100);
		border-color: var(--rose-200);
	}

	/* ── Education ── */
	.education-section {
		background: var(--tan-100);
	}
	.education-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		max-width: 900px;
		margin: 0 auto;
	}
	.edu-card {
		padding: 2rem;
	}
	.edu-icon {
		width: 56px;
		height: 56px;
		border-radius: var(--radius-md);
		background: var(--rose-50);
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 1.25rem;
	}
	.edu-card h3 {
		font-family: var(--font-inter), system-ui, sans-serif;
		font-size: 1.1rem;
		font-weight: 700;
		margin-bottom: 0.25rem;
	}
	.edu-school {
		font-size: 0.85rem;
		color: var(--rose-400);
		font-weight: 600;
		margin-bottom: 0.75rem;
	}
	.edu-detail {
		font-size: 0.9rem;
		color: var(--text-muted);
		line-height: 1.65;
		margin: 0;
	}

	/* ── CTA ── */
	.about-cta {
		background: var(--bg-primary);
	}
	.cta-card {
		text-align: center;
		padding: 4rem 3rem;
	}
	.cta-card h2 {
		margin-bottom: 1rem;
	}
	.cta-card p {
		color: var(--text-muted);
		max-width: 500px;
		margin: 0 auto 2rem;
	}

	/* ── Responsive ── */
	@media (max-width: 768px) {
		.about-hero-content {
			grid-template-columns: 1fr;
			gap: 2rem;
			text-align: center;
		}
		.about-hero-text .section-label {
			text-align: center;
		}
		.about-hero-text h1 {
			font-size: 2.25rem;
		}
		.about-img-container {
			max-width: 280px;
		}
		.about-img-accent {
			top: 12px;
			right: -12px;
			bottom: -12px;
			left: 12px;
		}
		.bio-content {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.expertise-grid,
		.education-grid {
			grid-template-columns: 1fr;
		}
		.cta-card {
			padding: 3rem 1.5rem;
		}
	}
</style>
