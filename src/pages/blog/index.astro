---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featuredPost, ...otherPosts] = posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead 
			title={`Blog — ${SITE_TITLE}`} 
			description="Insights on marketing strategy, brand development, business growth, and the art of building meaningful connections." 
		/>
	</head>
	<body>
		<Header />
		<main class="blog-page">
			<!-- Page Header -->
			<section class="page-hero">
				<div class="container">
					<p class="section-label">Blog</p>
					<h1>Insights & <span class="gradient-text">Ideas</span></h1>
					<p class="page-desc">
						Thoughts on marketing, business development, and the strategies 
						that drive meaningful growth.
					</p>
				</div>
			</section>

			<!-- Featured Post -->
			{featuredPost && (
				<section class="featured-section">
					<div class="container">
						<a href={`/blog/${featuredPost.id}/`} class="featured-post card">
							<div class="featured-image">
								{featuredPost.data.heroImage && (
									<Image 
										width={800} 
										height={400} 
										src={featuredPost.data.heroImage} 
										alt={featuredPost.data.title}
										class="featured-img"
									/>
								)}
								<div class="featured-badge">Latest</div>
							</div>
							<div class="featured-body">
								<span class="featured-date">
									<FormattedDate date={featuredPost.data.pubDate} />
								</span>
								<h2 class="featured-title">{featuredPost.data.title}</h2>
								<p class="featured-desc">{featuredPost.data.description}</p>
								<span class="read-more">
									Read Article
									<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
								</span>
							</div>
						</a>
					</div>
				</section>
			)}

			<!-- All Posts Grid -->
			<section class="posts-section section-sm">
				<div class="container">
					{otherPosts.length > 0 && (
						<h3 class="posts-heading">More Articles</h3>
					)}
					<div class="posts-grid">
						{otherPosts.map(post => (
							<a href={`/blog/${post.id}/`} class="post-card card">
								{post.data.heroImage && (
									<div class="post-image-wrapper">
										<Image 
											width={400} 
											height={240} 
											src={post.data.heroImage} 
											alt={post.data.title}
											class="post-img"
										/>
									</div>
								)}
								<div class="post-body">
									<span class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<h4 class="post-title">{post.data.title}</h4>
									<p class="post-desc">{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 100%;
		padding: 0;
	}
	.section-label {
		text-align: center;
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--rose-400);
		margin-bottom: 0.75rem;
	}

	/* ── Page Hero ── */
	.page-hero {
		padding: calc(var(--nav-height) + 4rem) 0 3rem;
		background: linear-gradient(180deg, var(--tan-50), var(--rose-50));
		text-align: center;
	}
	.page-hero h1 {
		font-size: 3rem;
		margin-bottom: 1rem;
	}
	.page-desc {
		font-size: 1.1rem;
		color: var(--text-muted);
		max-width: 550px;
		margin: 0 auto;
		line-height: 1.7;
	}

	/* ── Featured Post ── */
	.featured-section {
		padding: 2rem 0 0;
	}
	.featured-post {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		overflow: hidden;
		text-decoration: none;
		cursor: pointer;
	}
	.featured-image {
		position: relative;
		overflow: hidden;
	}
	.featured-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.5s ease;
	}
	.featured-post:hover .featured-img {
		transform: scale(1.03);
	}
	.featured-badge {
		position: absolute;
		top: 1rem;
		left: 1rem;
		padding: 0.35rem 1rem;
		background: linear-gradient(135deg, var(--rose-400), var(--rose-500));
		color: #fff;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		border-radius: var(--radius-full);
	}
	.featured-body {
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.featured-date {
		font-size: 0.85rem;
		color: var(--text-muted);
		font-weight: 500;
		margin-bottom: 0.75rem;
	}
	.featured-title {
		font-size: 1.75rem;
		color: var(--text-primary);
		margin-bottom: 1rem;
		line-height: 1.3;
		transition: color var(--transition-fast);
	}
	.featured-post:hover .featured-title {
		color: var(--rose-500);
	}
	.featured-desc {
		font-size: 0.95rem;
		color: var(--text-muted);
		line-height: 1.7;
		margin-bottom: 1.5rem;
	}
	.read-more {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--rose-500);
		transition: gap var(--transition-base);
	}
	.featured-post:hover .read-more {
		gap: 0.75rem;
	}

	/* ── Posts Grid ── */
	.posts-heading {
		font-family: var(--font-inter), system-ui, sans-serif;
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 1.5rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}
	.post-card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		overflow: hidden;
	}
	.post-image-wrapper {
		overflow: hidden;
	}
	.post-img {
		width: 100%;
		height: 220px;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.5s ease;
	}
	.post-card:hover .post-img {
		transform: scale(1.05);
	}
	.post-body {
		padding: 1.25rem 1.5rem 1.5rem;
	}
	.post-date {
		font-size: 0.8rem;
		color: var(--text-muted);
		font-weight: 500;
	}
	.post-title {
		font-family: var(--font-inter), system-ui, sans-serif;
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0.5rem 0;
		line-height: 1.4;
		transition: color var(--transition-fast);
	}
	.post-card:hover .post-title {
		color: var(--rose-500);
	}
	.post-desc {
		font-size: 0.875rem;
		color: var(--text-muted);
		line-height: 1.6;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* ── Responsive ── */
	@media (max-width: 768px) {
		.featured-post {
			grid-template-columns: 1fr;
		}
		.featured-body {
			padding: 1.5rem;
		}
		.featured-title {
			font-size: 1.35rem;
		}
		.posts-grid {
			grid-template-columns: 1fr;
		}
		.page-hero h1 {
			font-size: 2.25rem;
		}
	}
</style>
