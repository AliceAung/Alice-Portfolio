---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	description: string;
	tags: string[];
	image: ImageMetadata;
	link?: string;
}

const { title, description, tags, image, link = '#' } = Astro.props;
---

<div class="portfolio-card card">
	<div class="card-image">
		<Image src={image} alt={title} width={600} height={400} class="card-img" />
		<div class="card-overlay">
			<a href={link} class="overlay-btn" aria-label={`View ${title}`}>
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="7" y1="17" x2="17" y2="7"></line>
					<polyline points="7 7 17 7 17 17"></polyline>
				</svg>
			</a>
		</div>
	</div>
	<div class="card-body">
		<div class="card-tags">
			{tags.map(tag => (
				<span class="tag">{tag}</span>
			))}
		</div>
		<h3 class="card-title">{title}</h3>
		<p class="card-desc">{description}</p>
	</div>
</div>

<style>
	.portfolio-card {
		overflow: hidden;
	}
	.card-image {
		position: relative;
		overflow: hidden;
		aspect-ratio: 3 / 2;
	}
	.card-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
		border-radius: 0;
	}
	.card-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(244, 63, 94, 0.7), rgba(190, 18, 60, 0.5));
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity var(--transition-base);
	}
	.portfolio-card:hover .card-img {
		transform: scale(1.05);
	}
	.portfolio-card:hover .card-overlay {
		opacity: 1;
	}
	.overlay-btn {
		width: 52px;
		height: 52px;
		border-radius: var(--radius-full);
		background: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--rose-500);
		text-decoration: none;
		transition: all var(--transition-base);
		transform: translateY(10px);
	}
	.portfolio-card:hover .overlay-btn {
		transform: translateY(0);
	}
	.overlay-btn:hover {
		background: var(--rose-50);
		transform: scale(1.1) translateY(0);
	}
	.card-body {
		padding: 1.5rem;
	}
	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}
	.tag {
		display: inline-block;
		padding: 0.2rem 0.65rem;
		background: var(--rose-50);
		color: var(--rose-500);
		border-radius: var(--radius-full);
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}
	.card-title {
		font-family: var(--font-inter), system-ui, sans-serif;
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 0.5rem;
	}
	.card-desc {
		font-size: 0.9rem;
		color: var(--text-muted);
		line-height: 1.6;
		margin: 0;
	}
</style>
