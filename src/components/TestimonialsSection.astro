---
const testimonials = [
	{
		quote: "Alice's strategic approach to brand development transformed our market presence. Her ability to identify opportunities and execute flawlessly is truly exceptional.",
		name: "James Whitfield",
		role: "CEO, Meridian Ventures",
		initials: "JW",
	},
	{
		quote: "Working with Alice was a game-changer for our digital marketing. She brought clarity to our strategy and delivered results that exceeded all expectations.",
		name: "Sophia Chen",
		role: "Marketing Director, Everbloom Co.",
		initials: "SC",
	},
	{
		quote: "Alice's market research insights helped us pivot at exactly the right time. Her data-driven recommendations are always thorough and actionable.",
		name: "Daniel Kessler",
		role: "Founder, BrightScale Analytics",
		initials: "DK",
	},
];
---

<section class="testimonials-section section" id="testimonials">
	<div class="container">
		<p class="section-label">Testimonials</p>
		<h2 class="section-title">What Clients <span class="gradient-text">Say</span></h2>
		<p class="section-subtitle">
			Trusted by leaders across industries to deliver strategic growth and meaningful results.
		</p>
		<div class="testimonials-grid">
			{testimonials.map((t, i) => (
				<div class={`testimonial-card delay-${i + 1}`}>
					<div class="quote-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="var(--rose-200)">
							<path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
						</svg>
					</div>
					<p class="quote-text">{t.quote}</p>
					<div class="quote-author">
						<div class="author-avatar">
							<span>{t.initials}</span>
						</div>
						<div class="author-info">
							<span class="author-name">{t.name}</span>
							<span class="author-role">{t.role}</span>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.testimonials-section {
		background: var(--tan-100);
	}
	.section-label {
		text-align: center;
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--rose-400);
		margin-bottom: 0.75rem;
	}
	.testimonials-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.testimonial-card {
		background: var(--bg-card);
		border: 1px solid var(--border-light);
		border-radius: var(--radius-lg);
		padding: 2rem;
		transition: all var(--transition-base);
		display: flex;
		flex-direction: column;
	}
	.testimonial-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
		border-color: var(--rose-200);
	}
	.quote-icon {
		margin-bottom: 1rem;
	}
	.quote-text {
		font-size: 0.95rem;
		color: var(--text-secondary);
		line-height: 1.75;
		flex: 1;
		font-style: italic;
		margin-bottom: 1.5rem;
	}
	.quote-author {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		border-top: 1px solid var(--border-light);
		padding-top: 1.25rem;
	}
	.author-avatar {
		width: 44px;
		height: 44px;
		border-radius: var(--radius-full);
		background: linear-gradient(135deg, var(--rose-100), var(--rose-200));
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.author-avatar span {
		font-family: var(--font-playfair), Georgia, serif;
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--rose-600);
	}
	.author-info {
		display: flex;
		flex-direction: column;
	}
	.author-name {
		font-weight: 700;
		font-size: 0.9rem;
		color: var(--text-primary);
	}
	.author-role {
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	@media (max-width: 1024px) {
		.testimonials-grid {
			grid-template-columns: 1fr 1fr;
		}
		.testimonial-card:last-child {
			grid-column: 1 / -1;
			max-width: 500px;
			margin: 0 auto;
		}
	}
	@media (max-width: 640px) {
		.testimonials-grid {
			grid-template-columns: 1fr;
		}
		.testimonial-card:last-child {
			max-width: none;
		}
	}
</style>
