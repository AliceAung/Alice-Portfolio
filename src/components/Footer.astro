---
const today = new Date();
---

<footer>
	<div class="container footer-content">
		<div class="footer-top">
			<div class="footer-brand">
				<a href="/" class="footer-logo">
					<span class="logo-text">Alice</span>
					<span class="logo-dot"></span>
				</a>
				<p class="footer-tagline">Marketing & Business Development Professional<br/>Crafting strategies that drive growth.</p>
			</div>
			<div class="footer-nav">
				<div class="footer-col">
					<h4>Navigate</h4>
					<a href="/">Home</a>
					<a href="/about">About</a>
					<a href="/portfolio">Portfolio</a>
				</div>
				<div class="footer-col">
					<h4>More</h4>
					<a href="/blog">Blog</a>
					<a href="/contact">Contact</a>
				</div>
			</div>
			<div class="footer-social">
				<h4>Connect</h4>
				<div class="social-links">
					<a href="https://linkedin.com" target="_blank" aria-label="LinkedIn">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
						</svg>
					</a>
					<a href="mailto:hello@aliceaung.com" aria-label="Email">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
							<path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
						</svg>
					</a>
				</div>
			</div>
		</div>
		<div class="footer-bottom">
			<div class="footer-divider"></div>
			<p class="copyright">&copy; {today.getFullYear()} Alice Aung. All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	footer {
		background: linear-gradient(180deg, var(--tan-50), var(--tan-100));
		padding: 4rem 0 2rem;
		border-top: 1px solid var(--border-light);
	}
	.footer-content {
		max-width: var(--max-width);
	}
	.footer-top {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr;
		gap: 3rem;
		margin-bottom: 3rem;
	}
	.footer-logo {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		text-decoration: none;
		margin-bottom: 1rem;
	}
	.logo-text {
		font-family: var(--font-playfair), Georgia, serif;
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--text-primary);
	}
	.logo-dot {
		width: 8px;
		height: 8px;
		background: var(--rose-400);
		border-radius: 50%;
		margin-top: 0.4rem;
	}
	.footer-tagline {
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
		margin: 0;
	}
	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.footer-col h4 {
		font-family: var(--font-inter), system-ui, sans-serif;
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-primary);
		margin-bottom: 0.5rem;
	}
	.footer-col a,
	.footer-nav a {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.95rem;
		transition: color var(--transition-fast);
	}
	.footer-col a:hover,
	.footer-nav a:hover {
		color: var(--rose-500);
	}
	.footer-social h4 {
		font-family: var(--font-inter), system-ui, sans-serif;
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-primary);
		margin-bottom: 0.75rem;
	}
	.social-links {
		display: flex;
		gap: 1rem;
	}
	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: var(--radius-full);
		background: var(--rose-50);
		color: var(--text-secondary);
		text-decoration: none;
		transition: all var(--transition-base);
		border: 1px solid var(--rose-100);
	}
	.social-links a:hover {
		background: var(--rose-400);
		color: #fff;
		transform: translateY(-2px);
		box-shadow: var(--shadow-rose);
		border-color: var(--rose-400);
	}
	.footer-divider {
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--rose-200), var(--tan-200), transparent);
		margin-bottom: 1.5rem;
	}
	.copyright {
		text-align: center;
		color: var(--text-muted);
		font-size: 0.875rem;
		margin: 0;
	}
	.footer-nav {
		display: flex;
		gap: 3rem;
	}

	@media (max-width: 768px) {
		.footer-top {
			grid-template-columns: 1fr;
			gap: 2rem;
			text-align: center;
		}
		.footer-logo {
			justify-content: center;
		}
		.footer-nav {
			justify-content: center;
		}
		.footer-social {
			display: flex;
			flex-direction: column;
			align-items: center;
		}
	}
</style>
