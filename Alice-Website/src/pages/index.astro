---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

import portfolioBrand from '../assets/portfolio-brand-strategy.jpg';
import portfolioDigital from '../assets/portfolio-digital-marketing.jpg';
import portfolioResearch from '../assets/portfolio-market-research.jpg';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const featuredProjects = [
	{
		title: 'Meridian Brand Refresh',
		description: 'Complete brand identity overhaul for a fintech startup, resulting in 40% increase in brand recognition.',
		tags: ['Brand Strategy', 'Identity Design'],
		image: portfolioBrand,
	},
	{
		title: 'Everbloom Digital Campaign',
		description: 'Multi-channel digital marketing campaign that drove 2.5x ROI within the first quarter.',
		tags: ['Digital Marketing', 'Social Media'],
		image: portfolioDigital,
	},
	{
		title: 'BrightScale Market Entry',
		description: 'Comprehensive market research and go-to-market strategy for Southeast Asian expansion.',
		tags: ['Market Research', 'Strategy'],
		image: portfolioResearch,
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- Hero Section -->
		<HeroSection />

		<!-- Skills & Services -->
		<SkillsSection />

		<!-- Featured Work -->
		<section class="featured-work section" id="featured-work">
			<div class="container">
				<p class="section-label">Featured Work</p>
				<h2 class="section-title">Recent <span class="gradient-text">Projects</span></h2>
				<p class="section-subtitle">
					A selection of recent campaigns and strategies that delivered measurable impact.
				</p>
				<div class="projects-grid">
					{featuredProjects.map(project => (
						<PortfolioCard 
							title={project.title}
							description={project.description}
							tags={project.tags}
							image={project.image}
						/>
					))}
				</div>
				<div class="section-cta">
					<a href="/portfolio" class="btn btn-secondary">
						View All Projects
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</a>
				</div>
			</div>
		</section>

		<!-- Testimonials -->
		<TestimonialsSection />

		<!-- Latest Blog Posts -->
		<section class="blog-preview section" id="blog-preview">
			<div class="container">
				<p class="section-label">From the Blog</p>
				<h2 class="section-title">Latest <span class="gradient-text">Insights</span></h2>
				<p class="section-subtitle">
					Thoughts on marketing, business growth, and the art of building meaningful connections.
				</p>
				<div class="blog-grid">
					{posts.map(post => (
						<a href={`/blog/${post.id}/`} class="blog-card card">
							{post.data.heroImage && (
								<Image 
									width={400} 
									height={220} 
									src={post.data.heroImage} 
									alt={post.data.title}
									class="blog-card-img"
								/>
							)}
							<div class="blog-card-body">
								<span class="blog-card-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<h3 class="blog-card-title">{post.data.title}</h3>
								<p class="blog-card-desc">{post.data.description}</p>
							</div>
						</a>
					))}
				</div>
				<div class="section-cta">
					<a href="/blog" class="btn btn-secondary">
						Read All Posts
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</a>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="cta-section" id="cta">
			<div class="container">
				<div class="cta-card glass-card">
					<div class="cta-bg-orb"></div>
					<h2>Let's Build Something <span class="gradient-text">Remarkable</span></h2>
					<p>Ready to elevate your brand and drive growth? I'd love to hear about your project.</p>
					<div class="cta-actions">
						<a href="/contact" class="btn btn-primary">
							Start a Conversation
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
						</a>
					</div>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>

<style>
	/* ── Section Labels ── */
	.section-label {
		text-align: center;
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--rose-400);
		margin-bottom: 0.75rem;
	}

	/* ── Featured Work ── */
	.featured-work {
		background: var(--bg-primary);
	}
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.section-cta {
		text-align: center;
		margin-top: 3rem;
	}

	/* ── Blog Preview ── */
	.blog-preview {
		background: var(--bg-primary);
	}
	.blog-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.blog-card {
		text-decoration: none;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}
	.blog-card-img {
		width: 100%;
		height: 200px;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.5s ease;
	}
	.blog-card:hover .blog-card-img {
		transform: scale(1.05);
	}
	.blog-card-body {
		padding: 1.25rem 1.5rem;
	}
	.blog-card-date {
		font-size: 0.8rem;
		color: var(--text-muted);
		font-weight: 500;
	}
	.blog-card-title {
		font-family: var(--font-inter), system-ui, sans-serif;
		font-size: 1.05rem;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0.5rem 0;
		line-height: 1.4;
	}
	.blog-card:hover .blog-card-title {
		color: var(--rose-500);
	}
	.blog-card-desc {
		font-size: 0.875rem;
		color: var(--text-muted);
		line-height: 1.6;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* ── CTA Section ── */
	.cta-section {
		padding: 5rem 0;
		background: var(--tan-100);
	}
	.cta-card {
		text-align: center;
		padding: 4rem 3rem;
		position: relative;
		overflow: hidden;
	}
	.cta-bg-orb {
		position: absolute;
		width: 300px;
		height: 300px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(251, 113, 133, 0.15), transparent);
		top: -100px;
		right: -100px;
		filter: blur(40px);
	}
	.cta-card h2 {
		font-size: 2.25rem;
		margin-bottom: 1rem;
		position: relative;
		z-index: 1;
	}
	.cta-card p {
		font-size: 1.05rem;
		color: var(--text-muted);
		max-width: 500px;
		margin: 0 auto 2rem;
		position: relative;
		z-index: 1;
	}
	.cta-actions {
		position: relative;
		z-index: 1;
	}

	/* ── Responsive ── */
	@media (max-width: 1024px) {
		.projects-grid,
		.blog-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (max-width: 640px) {
		.projects-grid,
		.blog-grid {
			grid-template-columns: 1fr;
		}
		.cta-card {
			padding: 3rem 1.5rem;
		}
		.cta-card h2 {
			font-size: 1.75rem;
		}
	}
</style>
