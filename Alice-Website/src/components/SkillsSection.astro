---
const skills = [
	{
		icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>`,
		title: 'Marketing Strategy',
		description: 'Developing comprehensive marketing plans that align with business objectives and target audiences effectively.',
	},
	{
		icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg>`,
		title: 'Brand Development',
		description: 'Creating compelling brand identities that resonate with target markets and build lasting customer loyalty.',
	},
	{
		icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>`,
		title: 'Market Research',
		description: 'Conducting thorough market analysis and competitive research to uncover insights and growth opportunities.',
	},
	{
		icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>`,
		title: 'Digital Marketing',
		description: 'Leveraging digital channels including social media, content marketing, and SEO to maximize brand visibility.',
	},
	{
		icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 00-3-3.87"></path><path d="M16 3.13a4 4 0 010 7.75"></path></svg>`,
		title: 'Business Development',
		description: 'Building strategic relationships and identifying new market opportunities to drive revenue and business growth.',
	},
	{
		icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`,
		title: 'Client Relations',
		description: 'Nurturing client partnerships through exceptional communication, trust-building, and results-driven service.',
	},
];
---

<section class="skills-section section" id="skills">
	<div class="container">
		<p class="section-label">What I Do</p>
		<h2 class="section-title">Expertise & <span class="gradient-text">Services</span></h2>
		<p class="section-subtitle">
			Combining strategic thinking with creative execution to deliver meaningful business outcomes.
		</p>
		<div class="skills-grid">
			{skills.map((skill, i) => (
				<div class={`skill-card delay-${i + 1}`}>
					<div class="skill-icon" set:html={skill.icon} />
					<h3 class="skill-title">{skill.title}</h3>
					<p class="skill-desc">{skill.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.skills-section {
		background: linear-gradient(180deg, var(--bg-primary) 0%, var(--rose-50) 50%, var(--bg-primary) 100%);
	}
	.section-label {
		text-align: center;
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--rose-400);
		margin-bottom: 0.75rem;
	}
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.skill-card {
		background: var(--bg-card);
		border: 1px solid var(--border-light);
		border-radius: var(--radius-lg);
		padding: 2rem;
		transition: all var(--transition-base);
		position: relative;
		overflow: hidden;
	}
	.skill-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(90deg, var(--rose-300), var(--rose-400), var(--rose-300));
		opacity: 0;
		transition: opacity var(--transition-base);
	}
	.skill-card:hover {
		transform: translateY(-6px);
		box-shadow: var(--shadow-lg);
		border-color: var(--rose-200);
	}
	.skill-card:hover::before {
		opacity: 1;
	}
	.skill-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		height: 56px;
		background: linear-gradient(135deg, var(--rose-50), var(--rose-100));
		border-radius: var(--radius-md);
		color: var(--rose-500);
		margin-bottom: 1.25rem;
		transition: all var(--transition-base);
	}
	.skill-card:hover .skill-icon {
		background: linear-gradient(135deg, var(--rose-400), var(--rose-500));
		color: #fff;
		transform: scale(1.05);
	}
	.skill-title {
		font-family: var(--font-inter), system-ui, sans-serif;
		font-size: 1.1rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}
	.skill-desc {
		font-size: 0.9rem;
		color: var(--text-muted);
		line-height: 1.65;
		margin: 0;
	}

	@media (max-width: 1024px) {
		.skills-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 640px) {
		.skills-grid {
			grid-template-columns: 1fr;
		}
		.skill-card {
			padding: 1.5rem;
		}
	}
</style>
